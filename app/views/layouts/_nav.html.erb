<nav id="nav">
  <ul>
    <div class="general-links">
      <%# TODO: see if we can handle the active thing here in a more Rails-y way %>
      <li>
        <%= link_to t("layout.nav.home"), root_url, class: request.path == "/" ? 'active' : nil %>
      </li>
      <li>
        <%= link_to t("layout.nav.about"), about_url, class: request.path == "/about" ? 'active' : nil %>
      </li>
      <li>
        <%= link_to t("layout.nav.contact"), contact_url, class: request.path == "/contact" ? 'active' : nil %>
      </li>
      <li id="main-cart">
        <%= link_to cart_url, class: request.path == "/cart" ? 'active' : nil do %>
          <i class="svg cart-icon icon" aria-label="Cart"></i>
        <% end %>
      </li>
    </div>

    <div class="session-links">
      <% if user_signed_in? %>
        <li>
          <%= t("layout.user.signed_in", email: current_user.email) %>
        </li>
        <li>
          <%= link_to t("layout.user.log_out"), destroy_user_session_path, data: { turbo_method: :delete } %>
        </li>
      <% else %>
        <li>
          <%= link_to t("layout.user.sign_in"), new_user_session_path %>
        </li>
        <li>
          <%= link_to t("layout.user.sign_up"), new_user_registration_path %>
        </li>
      <% end %>
    </div>

    <%= image_tag "close-icon.svg", id: "close-icon", class: "icon" %>
  </ul>

</nav>

<div class="mobile">
  <%= link_to cart_url do %>
    <i class="svg cart-icon icon" aria-label="Cart"></i>
  <% end %>

  <%= image_tag "icon-hamburger.svg", id: "hamburger-icon", class: "icon" %>
</div>

<script>
  const hamburger = document.getElementById("hamburger-icon");
  const close = document.getElementById("close-icon");

  const navbar = document.getElementById("nav").firstElementChild;

  if(hamburger) {
    hamburger.addEventListener("click", () => {
      navbar.classList.add("open");
    });
  }


  if(close) {
    close.addEventListener("click", () => {
      navbar.classList.remove("open");
    });
  }
</script>
